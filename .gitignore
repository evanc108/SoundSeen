# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
env/

# Node / Next.js — soundseen-web/.gitignore covers most of this, but
# catch any stray installs anywhere in the tree.
node_modules/
.next/

# Environment variables (matches .env, .env.local, .env.production, etc.).
# Always commit a .env.example template instead.
.env
.env.*
!.env.example

# Audio uploads — never check in user-provided mp3/wav fixtures.
*.mp3

# Rendered videos — large MP4 outputs. Keep them out of the repo
# (GitHub 100 MB limit, and they're regeneratable from spec + audio).
renders/
*.mp4
*.mp4.video.mp4

# IDE
.idea/
.vscode/
*.swp

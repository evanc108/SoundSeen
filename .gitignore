# macOS
.DS_Store

# Local Xcode build output (repo-root)
.derivedData/
.derivedDataAgent/

# Xcode user-specific files
*.xcuserstate
xcuserdata/

# Python
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
env/

# Environment variables
.env

# Audio — ignore stray MP3s, but allow bundled app resources
*.mp3
!SoundSeen/SoundSeen/Resources/*.mp3

# Rendered videos — large MP4 outputs from the local renderer.
# Keep them out of the repo (GitHub 100 MB limit, and they're
# regeneratable from spec + audio anyway).
renders/
*.mp4
*.mp4.video.mp4

# IDE
.idea/
.vscode/
*.swp
